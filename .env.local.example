# WhatsApp / Meta Cloud API (only provider — Twilio was removed)
META_WHATSAPP_ACCESS_TOKEN=     # Meta permanent access token (System User, whatsapp_business_messaging scope)
META_WHATSAPP_PHONE_NUMBER_ID=  # Meta phone-number ID for +15616988477 (default sender)
META_WHATSAPP_VERIFY_TOKEN=     # Custom string used for GET /webhook verification handshake
META_APP_SECRET=                # App Secret for HMAC-SHA256 signature on x-hub-signature-256
# META_GRAPH_VERSION=v21.0      # Optional override; defaults to v21.0
# SKIP_META_SIGNATURE=1         # ONLY during onboarding before App Secret is set; never in prod

# Anthropic (AI)
ANTHROPIC_API_KEY=              # Claude API key

# Supabase
NEXT_PUBLIC_SUPABASE_URL=       # https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=  # Supabase anon/public key (for frontend auth)
SUPABASE_SERVICE_ROLE_KEY=      # Supabase service role key (for backend operations)

# Business Config
OPERATOR_PHONE=+15617024893     # Eduardo's WhatsApp for HANDOFF alerts
BUSINESS_PHONE=+15616988477     # Oiikon's WhatsApp Business number (registered with Meta Cloud API)
OIIKON_WEBSITE=https://oiikon.com

# ── Luz (daily marketing agent) ────────────────────────────────────────────
# All marketing vars are OPTIONAL. Luz degrades gracefully without them:
#   - no SERPER_API_KEY → brief is generated from model knowledge only
#   - no HEYGEN_*       → skips video, returns pending_approval_no_video
#   - no META_*         → dashboard approval works, but no auto-publish
#   - no YOUTUBE_*      → no YouTube upload
#   - no META_WHATSAPP_* (from WhatsApp section) → WhatsApp preview is skipped

CRON_SECRET=                    # Bearer token for /api/cron/* (required in prod)
MARKETING_CRON_ENABLED=true     # Set to 'false' to disable daily run

# Research (Google search grounding — free tier ~2.5k queries/mo at serper.dev)
SERPER_API_KEY=

# Video generation (paid — heygen.com)
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Meta publishing (Facebook + Instagram Business)
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=         # Needs pages_manage_posts, instagram_content_publish
META_IG_ACCOUNT_ID=
META_AD_ACCOUNT_ID=             # For ads-insights (optional)

# YouTube upload
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=          # Scope: youtube.upload
