{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "app/api/webhook/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/sync-inventory/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/refresh-competitors/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/send-followups/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-inventory",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/refresh-competitors",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/send-followups",
      "schedule": "0 * * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
